# SwarmCast API — environment configuration
# Copy this file to api/.env and fill in your values.

# OpenAI API key — required only for swarm elicitation and LLM strategic mode.
# Vectorized simulation (default) works without this.
# Either key name is accepted; SWARMCAST_OPENAI_API_KEY takes priority.
OPENAI_API_KEY=sk-...
# SWARMCAST_OPENAI_API_KEY=sk-...

# Optional overrides (defaults shown)
# SWARMCAST_MAX_UPLOAD_BYTES=20971520   # 20 MB
# SWARMCAST_DEFAULT_N_POPULATION=1000
# SWARMCAST_DEFAULT_NUM_ROUNDS=16
